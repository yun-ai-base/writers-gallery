---
import '../styles/global.css';

const title = Astro.props.title || '百位作家画廊';
const jsonLd = Astro.props.jsonLd || '';
const base = (import.meta.env.BASE_URL || '/').replace(/\/$/, '') + '/';

const navLinks = [
  { label: '首页', href: base, icon: '🏠' },
  { label: '时间线', href: base + 'timeline.html', icon: '📜' },
  { label: '对比', href: base + 'compare.html', icon: '⚖️' },
  { label: '收藏', href: base + 'favorites.html', icon: '❤️' },
];

const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="百位中外著名作家及其作品 - 文学探索之旅" />
  <meta name="theme-color" content="#f7f2e7" />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content="百位中外著名作家及其作品 - 从鲁迅到莎士比亚，横跨东西方的文学宇宙" />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="zh_CN" />

  <!-- PWA -->
  <link rel="manifest" href={base + 'manifest.json'} />
  <link rel="icon" type="image/svg+xml" href={base + 'images/seal-stamp.svg'} />

  <!-- Twin Universe -->
  <link rel="stylesheet" href="https://yun-ai-base.github.io/psychscope/twin-universe.css" />

  <!-- JSON-LD -->
  {jsonLd && <script type="application/ld+json" set:html={jsonLd} />}

  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;500;600;700;900&family=Noto+Sans+SC:wght@400;500;600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body>
  <nav class="site-nav">
    <a href={base} class="nav-brand">
      <div class="brand-seal"></div>
      百位作家画廊
    </a>
    <ul class="nav-links">
      {navLinks.map(link => (
        <li><a href={link.href} class={currentPath === link.href ? 'active' : ''}>{link.label}</a></li>
      ))}
      <li>
        <button class="theme-btn" id="themeToggle" title="切换主题">
          <span id="themeIcon">🌙</span>
        </button>
      </li>
    </ul>
  </nav>

  <main class="page-wrap">
    <slot />

    <!-- Twin Universe (homepage only) -->
    {currentPath === base && <section class="section" id="twin-universe" style="padding:60px 20px;max-width:1200px;margin:0 auto">
      <h2 class="section-title" style="font-size:28px;font-weight:700;text-align:center;color:var(--c-text);margin-bottom:8px">🧬 孪生宇宙</h2>
      <p class="section-subtitle" style="font-size:14px;text-align:center;color:var(--c-text-dim);margin-bottom:36px">我的其他项目 · 点击跳转探索</p>
      <div class="twin-container" id="twin-container"></div>
    </section>}
  </main>

  <!-- Mobile bottom tab navigation -->
  <nav class="mobile-tab-bar">
    {navLinks.map(link => (
      <a href={link.href} class={`mobile-tab-item ${currentPath === link.href ? 'active' : ''}`}>
        <span class="mobile-tab-icon">{link.icon}</span>
        <span class="mobile-tab-label">{link.label}</span>
      </a>
    ))}
  </nav>

  <footer class="site-footer">
    <div class="footer-seal"></div>
    百位作家画廊 · 一百位中外著名作家及其作品
    <div class="footer-divider"></div>
    探索文学的永恒之光
  </footer>

  <script>
    // Theme toggle
    const toggle = document.getElementById('themeToggle');
    const icon = document.getElementById('themeIcon');
    const stored = localStorage.getItem('theme');
    if (stored === 'dark') {
      document.documentElement.setAttribute('data-theme', 'dark');
      icon.textContent = '☀️';
      document.querySelector('meta[name="theme-color"]').content = '#0f0e0a';
    }
    toggle.addEventListener('click', () => {
      const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
      if (isDark) {
        document.documentElement.removeAttribute('data-theme');
        localStorage.setItem('theme', 'light');
        icon.textContent = '🌙';
        document.querySelector('meta[name="theme-color"]').content = '#f7f2e7';
      } else {
        document.documentElement.setAttribute('data-theme', 'dark');
        localStorage.setItem('theme', 'dark');
        icon.textContent = '☀️';
        document.querySelector('meta[name="theme-color"]').content = '#0f0e0a';
      }
    });
  </script>
  <script src="https://yun-ai-base.github.io/psychscope/twin-universe.js" data-project="writers-gallery"></script>
</body>
</html>
